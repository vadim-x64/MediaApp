<Window x:Class="MediaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaApp"
        WindowState="Normal"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ThemeBg}"
        mc:Ignorable="d"
        Title="MediaApp" Height="550" Width="870"
        Icon="Resources/icon.ico"
        PreviewKeyDown="Window_PreviewKeyDown"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <local:CircularProgressConverter x:Key="CircularProgressConverter" />
        <Style TargetType="ListBoxItem">
            
            <Setter Property="Background" Value="{StaticResource ThemeCardBg}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="5,3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Template">

                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.IsGridView, RelativeSource={RelativeSource AncestorType=ListBox}}" Value="True">
                    <Setter Property="Padding" Value="6" />
                    <Setter Property="Margin" Value="4" />
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ThemeBlue}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ThemeBlueAccent}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E3F2FD" />
                    <Setter Property="BorderBrush" Value="#64B5F6" />
                </Trigger>
                <DataTrigger Binding="{Binding IsDuplicate}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DuplicateBg}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DuplicateBorder}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="0" MouseLeftButtonDown="Grid_MouseLeftButtonDown" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Margin="5,5,5,10">
            <!-- Ліва частина: твоє меню -->
            <Menu Background="Transparent" HorizontalAlignment="Left" VerticalAlignment="Center">
                <MenuItem Header="Файл" Foreground="{StaticResource TextPrimary}">
                    <MenuItem x:Name="OpenMenuItem" Header="Відкрити" Click="SelectFilesButton_Click" />
                    <Separator />
                    <MenuItem Header="Вийти" Click="ExitMenuItem_Click" />
                </MenuItem>
                <MenuItem Header="Інструменти" Foreground="{StaticResource TextPrimary}">
                    <MenuItem x:Name="CheckDuplicatesMenuItem" Header="Перевірити"
                      Click="CheckDuplicatesButton_Click"
                      IsEnabled="{Binding CanCheckDuplicates}" />
                    <Separator />
                    <MenuItem x:Name="DeleteDuplicatesMenuItem" Header="Видалити дублікати"
                      Command="{Binding DeleteDuplicatesCommand}"
                      IsEnabled="{Binding CanDeleteDuplicates}" />
                    <Separator />
                    <MenuItem x:Name="DeleteAllFilesMenuItem" Header="Видалити всі файли (з диска)"
                      Command="{Binding DeleteAllFilesCommand}"
                      IsEnabled="{Binding CanClearFiles}" />
                    <Separator />
                    <MenuItem x:Name="ClearMenuItem" Header="Очистити список"
                      Click="ClearMenuItem_Click"
                      IsEnabled="{Binding CanClearFiles}" />
                </MenuItem>
                <MenuItem Header="Довідка" Foreground="{StaticResource TextPrimary}">
                    <MenuItem Header="Про програму" Click="AboutMenuItem_Click" />
                </MenuItem>
            </Menu>

            <!-- Права частина: Керування виглядом та оновлення -->
            <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal" Margin="0,0,10,0">

                <!-- Перемикачі вигляду -->
                <Border Background="{StaticResource ThemeCardBg}" BorderBrush="#E9ECEF" BorderThickness="1" CornerRadius="6" Margin="0,0,15,0" Padding="2">
                    <StackPanel Orientation="Horizontal">
                        <!-- Використовуємо Style="{StaticResource {x:Type ToggleButton}}" щоб RadioButton виглядав як стильна кнопка-таба -->
                        <RadioButton Content="📄 Список" 
                         IsChecked="{Binding IsListView}" 
                         Style="{StaticResource {x:Type ToggleButton}}"
                         Background="Transparent" BorderThickness="0" Padding="8,4" FontSize="12" Cursor="Hand"/>
                        <RadioButton Content="🔲 Плитка" 
                         IsChecked="{Binding IsGridView}" 
                         Style="{StaticResource {x:Type ToggleButton}}"
                         Background="Transparent" BorderThickness="0" Padding="8,4" FontSize="12" Cursor="Hand"/>
                    </StackPanel>
                </Border>

                <!-- Кнопка оновлення -->
                <Button Command="{Binding RefreshListCommand}"
            ToolTip="Перевірити наявність файлів на диску та оновити список"
            Cursor="Hand"
            Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondary}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔄" FontSize="14" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Оновити" FontSize="13" VerticalAlignment="Center" FontWeight="Medium"/>
                    </StackPanel>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Opacity" Value="0.7"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter Property="Foreground" Value="{StaticResource ThemeBlueDark}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.3"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <ListBox Grid.Row="2"
                 x:Name="FileListBox"
                 SelectionMode="Extended"
                 SelectionChanged="FileListBox_SelectionChanged"
                 ItemsSource="{Binding MediaFiles}"
                 Background="Transparent"
                 BorderThickness="0"
                 Margin="10,0"
                 ScrollViewer.VerticalScrollBarVisibility="Visible"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 MouseDoubleClick="FileListBox_MouseDoubleClick"
                 AllowDrop="True"
                 Drop="FileListBox_Drop"
                 DragEnter="FileListBox_DragEnter"
                 DragLeave="FileListBox_DragLeave"
                 DragOver="FileListBox_DragOver">

            <ListBox.Template>
                <ControlTemplate TargetType="ListBox">
                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}">
                        <Grid>
                            <ScrollViewer x:Name="PART_ScrollViewer" Focusable="false">
                                <ItemsPresenter />
                            </ScrollViewer>
                            <StackPanel x:Name="EmptyStateOverlay"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Opacity="0.6">
                                <TextBlock Text="📁"
                                           FontSize="64"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15" />
                                <TextBlock Text="Перетягніть медіафайли сюди&#x0a;або використайте меню «Файл»"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                            </StackPanel>
                            <Border x:Name="DragOverlay"
                                    Background="#4081D4FA"
                                    BorderBrush="{StaticResource ThemeBlueAccent}"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Visibility="Collapsed">
                            </Border>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding MediaFiles.Count}" Value="0">
                            <Setter TargetName="EmptyStateOverlay" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding MediaFiles.Count, Converter={x:Static local:GreaterThanZeroConverter.Instance}}"
                            Value="True">
                            <Setter TargetName="EmptyStateOverlay" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ListBox.Template>

            <ListBox.Resources>
                <DataTemplate x:Key="ListViewTemplate">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0" 
                      IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}"
                      VerticalAlignment="Center" 
                      Margin="0,0,10,0">
                            <CheckBox.LayoutTransform>
                                <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                            </CheckBox.LayoutTransform>
                        </CheckBox>

                        <TextBlock Grid.Column="1"
                       Text="{Binding FileTypeIcon}"
                       FontSize="16"
                       VerticalAlignment="Center"
                       Margin="0,0,15,0" />

                        <TextBlock Grid.Column="2"
                       Text="{Binding FilePath}"
                       FontSize="13"
                       Foreground="{StaticResource TextPrimary}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis" />

                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                            <Grid Margin="0,0,5,0">
                                <TextBlock x:Name="CopySuccessIndicator"
                               Text="✔️"
                               Foreground="{StaticResource ThemeBlueDark}"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed" />

                                <Button Content="📋"
                            ToolTip="Копіювати шлях"
                            Foreground="{StaticResource TextSecondary}"
                            FontSize="14"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="5"
                            VerticalAlignment="Center"
                            Cursor="Hand"
                            Click="CopyPathButton_Click"
                            Tag="{Binding FilePath}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Opacity" Value="0.3" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background"
                                                            Value="{StaticResource ThemeBlueAccent}" />
                                                                <Setter Property="Foreground" Value="#FFFFFF" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <DataTrigger
                                        Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}"
                                        Value="True">
                                                    <Setter Property="Opacity" Value="1" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>

                            <Button Content="🗑️"
                        ToolTip="Видалити файл з диска"
                        Foreground="{StaticResource TextSecondary}"
                        FontSize="14"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="5"
                        VerticalAlignment="Center"
                        Cursor="Hand"
                        Click="DeleteSelectedFileButton_Click"
                        Tag="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Opacity" Value="0.3" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#FFCDD2" />
                                                            <Setter Property="Foreground" Value="#D32F2F" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}" Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </DataTemplate>

                <DataTemplate x:Key="GridViewTemplate">
                    <Grid Width="140" Height="160">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,5">
                            <CheckBox HorizontalAlignment="Left" VerticalAlignment="Center"
                          IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}">
                                <CheckBox.LayoutTransform>
                                    <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                </CheckBox.LayoutTransform>
                            </CheckBox>
                            <Button HorizontalAlignment="Right" Content="🗑️" ToolTip="Видалити"
                        Background="Transparent" BorderThickness="0" Foreground="#D32F2F" Cursor="Hand" Padding="2"
                        Click="DeleteSelectedFileButton_Click" Tag="{Binding}" />
                        </Grid>

                        <Border Grid.Row="1" Background="#F0F2F5" CornerRadius="6" ClipToBounds="True">
                            <Grid>
                                <TextBlock Text="{Binding FileTypeIcon}" FontSize="48"
                               HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>

                                <Image Stretch="UniformToFill" Source="{Binding FilePath, IsAsync=True}" RenderOptions.BitmapScalingMode="LowQuality">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FileType}" Value="Image">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="2" Text="{Binding FileName}" FontSize="12" Foreground="{StaticResource TextPrimary}"
                       TextTrimming="CharacterEllipsis" TextAlignment="Center" ToolTip="{Binding FileName}" Margin="0,5,0,0" />
                    </Grid>
                </DataTemplate>
            </ListBox.Resources>

            <ListBox.Style>
                <Style TargetType="ListBox">
                    <Setter Property="ItemTemplate" Value="{StaticResource ListViewTemplate}" />
                    <Setter Property="ItemsPanel">
                        <Setter.Value>
                            <ItemsPanelTemplate>
                                <VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling" />
                            </ItemsPanelTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsGridView}" Value="True">
                            <Setter Property="ItemTemplate" Value="{StaticResource GridViewTemplate}" />
                            <Setter Property="ItemsPanel">
                                <Setter.Value>
                                    <ItemsPanelTemplate>
                                        <WrapPanel IsItemsHost="True" Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ListBox.Style>
        </ListBox>

        <Grid Grid.Row="3" Margin="20,10,20,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="{Binding FileCountText}" 
                       FontSize="13" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />

            <Button Grid.Column="1" x:Name="MassDeleteButton" Content="🗑️ Видалити обрані" 
                    Visibility="Collapsed" Click="MassDeleteButton_Click"
                    Padding="15,6" Background="#FFEBEE" Foreground="#D32F2F" 
                    BorderBrush="#FFCDD2" BorderThickness="1" Cursor="Hand" FontWeight="SemiBold">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <StackPanel Grid.Row="4" Margin="20,5,20,10" Visibility="{Binding ProgressVisibility}">
            <TextBlock Text="{Binding ProgressText}"
                       Foreground="{StaticResource TextPrimary}"
                       HorizontalAlignment="Left"
                       FontSize="13"
                       Margin="0,0,0,5" />

            <ProgressBar Height="6"
                         Value="{Binding ProgressValue}"
                         Minimum="0" Maximum="100"
                         Background="#E0E0E0"
                         BorderThickness="0">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                        <Grid>
                                            <Rectangle Name="PART_Track" Fill="Transparent" />
                                            <Border Name="PART_Indicator"
                                                    Background="{StaticResource ThemeBlueDark}"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Left" />
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
        </StackPanel>

        <TextBlock Grid.Row="5"
                   Text="{Binding ResultMessage}"
                   Visibility="{Binding ResultVisibility}"
                   Foreground="{Binding ResultTextColor}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="20,0,20,15"
                   TextWrapping="Wrap" />

        <Border Grid.Row="2" Grid.RowSpan="3" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,20"
                Background="#2C3E50" BorderBrush="#34495E" BorderThickness="1" CornerRadius="22" Padding="15,6,6,6"
                Visibility="{Binding CancelPanelVisibility}" Panel.ZIndex="100">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="{Binding CancelMessage}" Foreground="White" FontSize="14" 
                           VerticalAlignment="Center" Margin="0,0,15,0" />

                <Grid Width="30" Height="30" Margin="0,0,8,0">
                    <Ellipse Stroke="#465A6E" StrokeThickness="3" Width="30" Height="30" />
                    <Ellipse Stroke="#EF5350" StrokeThickness="3" Width="30" Height="30" 
                             StrokeDashArray="{Binding CancelProgress, Converter={StaticResource CircularProgressConverter}}"
                             StrokeDashCap="Round" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.RenderTransform>
                            <RotateTransform Angle="-90" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <TextBlock Text="{Binding CancelCountdownText}" Foreground="White" FontSize="13" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Grid>

                <Button Command="{Binding CancelDeleteCommand}" 
                        Background="Transparent" BorderThickness="0" Cursor="Hand" Width="30" Height="30">
                    <TextBlock Text="✕" Foreground="#B0BEC5" FontSize="16" FontWeight="Bold" 
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Button>

            </StackPanel>
        </Border>
    </Grid>
</Window>