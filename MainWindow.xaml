<Window x:Class="MediaApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MediaApp"
        WindowState="Normal"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource ThemeBg}"
        mc:Ignorable="d"
        Title="MediaApp" Height="550" Width="850"
        Icon="Resources/icon.ico"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Background" Value="{StaticResource ThemeCardBg}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="5,3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#E0E0E0" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource ThemeBlue}" />
                    <Setter Property="BorderBrush" Value="{StaticResource ThemeBlueAccent}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsDuplicate}" Value="True">
                    <Setter Property="Background" Value="{StaticResource DuplicateBg}" />
                    <Setter Property="BorderBrush" Value="{StaticResource DuplicateBorder}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="0" MouseLeftButtonDown="Grid_MouseLeftButtonDown" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Menu Grid.Row="1" Background="Transparent" Margin="5,5,5,10">
            <MenuItem Header="Файл" Foreground="{StaticResource TextPrimary}">
                <MenuItem x:Name="OpenMenuItem" Header="Відкрити" Click="SelectFilesButton_Click" />
                <Separator />
                <MenuItem Header="Вийти" Click="ExitMenuItem_Click" />
            </MenuItem>
            <MenuItem Header="Інструменти" Foreground="{StaticResource TextPrimary}">
                <MenuItem x:Name="CheckDuplicatesMenuItem" Header="Перевірити"
                          Click="CheckDuplicatesButton_Click"
                          IsEnabled="{Binding CanCheckDuplicates}" />
                <Separator />
                <MenuItem x:Name="DeleteDuplicatesMenuItem" Header="Видалити дублікати"
                          Command="{Binding DeleteDuplicatesCommand}"
                          IsEnabled="{Binding CanDeleteDuplicates}" />
                <Separator />
                <MenuItem x:Name="ClearMenuItem" Header="Очистити"
                          Click="ClearMenuItem_Click"
                          IsEnabled="{Binding CanClearFiles}" />
            </MenuItem>
            <MenuItem Header="Довідка" Foreground="{StaticResource TextPrimary}">
                <MenuItem Header="Про програму" Click="AboutMenuItem_Click" />
            </MenuItem>
        </Menu>

        <ListBox Grid.Row="2"
                 x:Name="FileListBox"
                 ItemsSource="{Binding MediaFiles}"
                 Background="Transparent"
                 BorderThickness="0"
                 Margin="10,0"
                 ScrollViewer.VerticalScrollBarVisibility="Visible"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingStackPanel.IsVirtualizing="True"
                 VirtualizingStackPanel.VirtualizationMode="Recycling"
                 MouseDoubleClick="FileListBox_MouseDoubleClick"
                 AllowDrop="True"
                 Drop="FileListBox_Drop"
                 DragEnter="FileListBox_DragEnter"
                 DragLeave="FileListBox_DragLeave"
                 DragOver="FileListBox_DragOver">

            <ListBox.Template>
                <ControlTemplate TargetType="ListBox">
                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Background="{TemplateBinding Background}">
                        <Grid>
                            <ScrollViewer x:Name="PART_ScrollViewer" Focusable="false">
                                <ItemsPresenter />
                            </ScrollViewer>
                            <StackPanel x:Name="EmptyStateOverlay"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Opacity="0.6">
                                <TextBlock Text="📁"
                                           FontSize="64"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,15" />
                                <TextBlock Text="Перетягніть медіафайли сюди&#x0a;або використайте меню «Файл»"
                                           Foreground="{StaticResource TextSecondary}"
                                           FontSize="16"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center" />
                            </StackPanel>
                            <Border x:Name="DragOverlay"
                                    Background="#4081D4FA"
                                    BorderBrush="{StaticResource ThemeBlueAccent}"
                                    BorderThickness="2"
                                    CornerRadius="8"
                                    Visibility="Collapsed">
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding MediaFiles.Count}" Value="0">
                            <Setter TargetName="EmptyStateOverlay" Property="Visibility" Value="Visible" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding MediaFiles.Count, Converter={x:Static local:GreaterThanZeroConverter.Instance}}"
                            Value="True">
                            <Setter TargetName="EmptyStateOverlay" Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ListBox.Template>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding FileTypeIcon}"
                                   FontSize="16"
                                   VerticalAlignment="Center"
                                   Margin="0,0,15,0" />

                        <TextBlock Grid.Column="1"
                                   Text="{Binding FilePath}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextPrimary}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />

                        <Grid Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                            <TextBlock x:Name="CopySuccessIndicator"
                                       Text="✔️"
                                       Foreground="{StaticResource ThemeBlueDark}"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Visibility="Collapsed" />

                            <Button Content="📋"
                                    ToolTip="Копіювати шлях"
                                    Foreground="{StaticResource TextSecondary}"
                                    FontSize="14"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="5"
                                    VerticalAlignment="Center"
                                    Cursor="Hand"
                                    Click="CopyPathButton_Click"
                                    Tag="{Binding FilePath}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Opacity" Value="0.3" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background"
                                                                    Value="{StaticResource ThemeBlueAccent}" />
                                                            <Setter Property="Foreground" Value="#FFFFFF" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <DataTrigger
                                                Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsMouseOver}"
                                                Value="True">
                                                <Setter Property="Opacity" Value="1" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="3"
                   Text="{Binding FileCountText}"
                   HorizontalAlignment="Center"
                   FontSize="13"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="10" />

        <StackPanel Grid.Row="4" Margin="20,5,20,10" Visibility="{Binding ProgressVisibility}">
            <TextBlock Text="{Binding ProgressText}"
                       Foreground="{StaticResource TextPrimary}"
                       HorizontalAlignment="Left"
                       FontSize="13"
                       Margin="0,0,0,5" />

            <ProgressBar Height="6"
                         Value="{Binding ProgressValue}"
                         Minimum="0" Maximum="100"
                         Background="#E0E0E0"
                         BorderThickness="0">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ProgressBar">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                        <Grid>
                                            <Rectangle Name="PART_Track" Fill="Transparent" />
                                            <Border Name="PART_Indicator"
                                                    Background="{StaticResource ThemeBlueDark}"
                                                    CornerRadius="3"
                                                    HorizontalAlignment="Left" />
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>
        </StackPanel>

        <TextBlock Grid.Row="5"
                   Text="{Binding ResultMessage}"
                   Visibility="{Binding ResultVisibility}"
                   Foreground="{Binding ResultTextColor}"
                   FontSize="14"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"
                   Margin="20,0,20,15"
                   TextWrapping="Wrap" />
    </Grid>
</Window>